---
// MenuCard.astro — Tarjeta individual de plato del menú
import { Image } from 'astro:assets';

interface Props {
  name: string;
  description: string;
  category: string;
  imageSrc: string;    // ruta relativa a public/images/menu/
  imageAlt: string;
  price?: string;      // opcional
}

const { name, description, category, imageSrc, imageAlt, price } = Astro.props;

// Usar placeholder si imageSrc está vacío o no definido
const PLACEHOLDER = '/images/menu/placeholder.webp';
const resolvedSrc = imageSrc?.trim() ? imageSrc : PLACEHOLDER;
---

<article class="bg-cream rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 flex flex-col">
  <!-- Imagen del plato optimizada con Astro Image -->
  <div class="relative aspect-[4/3] overflow-hidden bg-dark/10">
    <Image
      src={resolvedSrc}
      alt={imageAlt}
      width={400}
      height={300}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
    />
    <!-- Etiqueta de categoría -->
    <span class="absolute top-3 left-3 bg-jungle-green text-cream text-xs font-sans font-semibold uppercase tracking-wide px-2 py-1 rounded-full">
      {category}
    </span>
  </div>

  <!-- Contenido de la tarjeta -->
  <div class="p-4 flex flex-col flex-1 gap-2">
    <h3 class="font-serif text-lg font-bold text-dark leading-snug">
      {name}
    </h3>
    <p class="font-sans text-sm text-dark/70 leading-relaxed flex-1">
      {description}
    </p>
    {price && (
      <p class="font-sans text-base font-bold text-peru-red mt-2">
        {price}
      </p>
    )}
  </div>
</article>
