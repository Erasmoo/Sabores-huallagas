---
// Ubicacion.astro — Sección de ubicación del restaurante
---

<section id="ubicacion" class="bg-white py-16 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="font-serif text-3xl sm:text-4xl font-bold text-dark mb-2">
      Ubicación
    </h2>
    <p class="font-sans text-jungle-green font-semibold text-lg mb-2">
      Centro selva de Pucallpa, Perú
    </p>
    <p class="font-sans text-dark/60 text-sm mb-8">
      Encuéntranos en el corazón de Pucallpa
    </p>

    <!-- Mapa embebido de Google Maps -->
    <div class="rounded-xl overflow-hidden shadow-lg border border-gold/20">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15955.123456789!2d-74.5539!3d-8.3791!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91ea15b1b1b1b1b1%3A0x1234567890abcdef!2sPucallpa%2C%20Per%C3%BA!5e0!3m2!1ses!2spe!4v1234567890"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Mapa de ubicación de Sabores Huallada de Perú en el Centro de Pucallpa"
      ></iframe>
    </div>

    <!-- Enlace a Google Maps en nueva pestaña -->
    <a
      href="https://maps.google.com/?q=Pucallpa,Peru"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block mt-6 font-sans text-sm font-semibold text-peru-red hover:text-jungle-green transition-colors duration-200 underline underline-offset-4"
    >
      Ver en Google Maps →
    </a>
  </div>
</section>
