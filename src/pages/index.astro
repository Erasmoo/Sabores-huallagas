---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import MenuGrid from '../components/MenuGrid.astro';
import Horarios from '../components/Horarios.astro';
import Ubicacion from '../components/Ubicacion.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const siteTitle = 'Sabores Huallada de Perú';
const siteDescription =
  'Bienvenido a Sabores Huallada de Perú, tu restaurante de cocina peruana en el Centro de Pucallpa. Disfruta de nuestro menú, conoce nuestros horarios y contáctanos.';
---

<Layout title={siteTitle} description={siteDescription}>
  <Navbar />

  <Hero
    title="Sabores Huallada de Perú"
    subtitle="Auténtica cocina peruana en el corazón de Pucallpa"
    imageSrc="/images/hero.webp"
    imageAlt="Platos típicos peruanos del restaurante Sabores Huallada de Perú"
  />

  <MenuGrid />

  <Horarios />

  <Ubicacion />

  <ContactForm />

  <Footer />
</Layout>
